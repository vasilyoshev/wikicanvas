# Copy to .env.local (gitignored) and fill in to enable Supabase sync + the Wikipedia proxy.
# All values are PUBLIC client values (anon/publishable) — safe to ship in a web bundle.
# Sync features are disabled when these are absent; the app still works fully local-first.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: the app's own public origin (used for web auth redirect URLs). Defaults to
# the Expo dev server when unset; set it for production web builds.
# EXPO_PUBLIC_PUBLIC_APP_URL=https://your-app.example.com

# Native (EAS) builds only — the EAS project UUID from `eas init`. Read into
# app.config.ts extra.eas.projectId. Not needed for web/local dev.
# EXPO_PUBLIC_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
