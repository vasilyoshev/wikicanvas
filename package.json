{
  "name": "wikicanvas",
  "main": "index.ts",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node --env-file=.env.local scripts/start-dev-client.js",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "export:web": "npm run setup:skia-web && npm exec expo -- export --platform web --clear",
    "setup:skia-web": "node node_modules/@shopify/react-native-skia/scripts/setup-canvaskit.js public",
    "serve:web:production": "npm exec expo -- serve",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "coverage:ratchet": "node scripts/check-coverage-ratchet.js",
    "coverage:ratchet:update": "node scripts/check-coverage-ratchet.js --update",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm run test:coverage && npm run coverage:ratchet",
    "db:start": "npm exec supabase -- start",
    "db:stop": "npm exec supabase -- stop",
    "db:status": "npm exec supabase -- status",
    "db:push:prod": "npm exec supabase -- db push --linked",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/noto-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@shopify/react-native-skia": "^2.0.0",
    "@supabase/supabase-js": "^2.103.2",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.0.8",
    "idb": "^8.0.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.6",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^56.0.15",
    "canvaskit-wasm": "^0.40.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jest-expo": "~54.0.17",
    "lint-staged": "^17.0.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write",
      "jest --findRelatedTests --bail --passWithNoTests"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
